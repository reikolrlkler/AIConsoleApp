  <ItemGroup>
    <PackageReference Include="OpenAI" Version="2.9.1" />
    <PackageReference Include="Anthropic" Version="12.5.0" />
    <PackageReference Include="Google.GenAI" Version="1.6.1" />
  </ItemGroup>
</Project>
